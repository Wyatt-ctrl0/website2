<section class="section">
  <div class="container" style="max-width: 900px;">
    <h1>Hi, {{ customer.first_name | default: 'friend' }} 🐾</h1>
    <p>Welcome to your account.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:2rem;">
      <div>
        <h3>Order History</h3>
        {%- if customer.orders.size > 0 -%}
          {%- for order in customer.orders -%}
            <div style="background:#fff;padding:1rem;border-radius:12px;margin-bottom:1rem;">
              <strong>{{ order.name }}</strong> · {{ order.created_at | date: '%b %d, %Y' }} · {{ order.total_price | money }}<br>
              <a href="{{ order.customer_url }}">View order</a>
            </div>
          {%- endfor -%}
        {%- else -%}
          <p>No orders yet.</p>
        {%- endif -%}
      </div>
      <div>
        <h3>Account</h3>
        <p>{{ customer.email }}</p>
        <a href="/account/addresses" class="btn btn-outline btn-sm">Manage addresses</a>
        <a href="/account/logout" class="btn btn-outline btn-sm">Log out</a>
      </div>
    </div>
  </div>
</section>
