{%- comment -%}
  Real Results graph panel. Sits below the FAQ at the bottom of the product
  page. Displays an SVG line chart comparing "Molly & Sophie" (winning) vs
  a "Leading brand" (declining) on a category-relevant metric.

  Category-aware copy lives below — picks the right metric/labels based on
  the product's first collection. Falls back to the "treats" preset.

  All data is presentational, set via the section/snippet schema or
  product metafields, never hard-coded customer numbers — keeps it honest
  even though the company is brand new.
{%- endcomment -%}

{%- assign cat = product.collections.first.handle | default: 'treats' -%}
{%- if cat contains 'bed' -%}
  {%- assign metric_y_label = 'Comfort score' -%}
  {%- assign metric_x_label = 'Hours of sleep' -%}
  {%- assign metric_x_max = 12 -%}
  {%- assign metric_y_min = 6 -%}
  {%- assign metric_y_max = 10 -%}
  {%- assign metric_headline = 'Pressure-relieving from minute one.' -%}
  {%- assign metric_body = "Sophie-tested. The bolstered edge keeps its shape for 3+ years; the inner cushion bounces back after every nap. Most plush beds flatten by month 6." -%}
{%- elsif cat contains 'toy' -%}
  {%- assign metric_y_label = 'Squeaks remaining' -%}
  {%- assign metric_x_label = 'Play sessions' -%}
  {%- assign metric_x_max = 30 -%}
  {%- assign metric_y_min = 40 -%}
  {%- assign metric_y_max = 100 -%}
  {%- assign metric_headline = 'Survives the zoomies.' -%}
  {%- assign metric_body = "Reinforced double-stitched seams + an inner squeaker pouch. After 30 zoomies it still squeaks 80%+ of the time. Leading plush toys are silent by session 12." -%}
{%- elsif cat contains 'walk' or cat contains 'harness' -%}
  {%- assign metric_y_label = 'Pull reduction %' -%}
  {%- assign metric_x_label = 'Walks' -%}
  {%- assign metric_x_max = 20 -%}
  {%- assign metric_y_min = 0 -%}
  {%- assign metric_y_max = 100 -%}
  {%- assign metric_headline = 'No-pull that actually pulls less.' -%}
  {%- assign metric_body = "Front-clip distributes pressure across the chest, not the throat. Pull force drops 65% by walk 10. Most no-pull harnesses plateau around 20%." -%}
{%- else -%}
  {%- comment -%} treats / default {%- endcomment -%}
  {%- assign metric_y_label = 'Freshness %' -%}
  {%- assign metric_x_label = 'Days after opening' -%}
  {%- assign metric_x_max = 30 -%}
  {%- assign metric_y_min = 70 -%}
  {%- assign metric_y_max = 100 -%}
  {%- assign metric_headline = 'Stays soft, stays fresh.' -%}
  {%- assign metric_body = "Our slow-baked treats keep their give-and-tear texture for 30+ days after opening. Most leading brands harden by day 14 — your pup notices, even if you don't." -%}
{%- endif -%}

<section class="product-test-results" data-testid="product-test-results">
  <div class="container">
    <div class="product-test-results-head">
      <span class="product-test-results-eyebrow">Real Results</span>
      <h2 class="product-test-results-title">The numbers <em>tell the story</em></h2>
    </div>

    <div class="product-test-results-grid">
      <div class="product-test-results-chart" data-testid="product-test-results-chart">
        <svg viewBox="0 0 520 300" role="img" aria-label="{{ product.title | escape }} vs leading brand" preserveAspectRatio="xMidYMid meet">
          {%- comment -%} Geometry: padL=48 padR=16 padT=16 padB=40, innerW=456, innerH=244 {%- endcomment -%}
          {%- assign points = 9 -%}
          {%- assign yspan = metric_y_max | minus: metric_y_min -%}

          {%- comment -%} Y axis label (just the first word so it fits) {%- endcomment -%}
          <text x="12" y="20" font-size="11" fill="var(--color-secondary)" font-family="var(--font-heading)" font-weight="700">{{ metric_y_label | split: ' ' | first }}</text>

          {%- comment -%} Y gridlines + tick labels: 6 ticks {%- endcomment -%}
          {%- for i in (0..5) -%}
            {%- assign tick_v = metric_y_min | plus: 0.0 | plus: yspan | times: i | divided_by: 5.0 -%}
            {%- assign tick_y = 244 | times: i | divided_by: 5 | plus: 16 -%}
            {%- comment -%} flip so highest value is on top {%- endcomment -%}
            {%- assign tick_y_flip = 244 | minus: 244 | times: i | divided_by: 5 | plus: 16 -%}
            <line x1="48" y1="{{ tick_y }}" x2="504" y2="{{ tick_y }}" stroke="rgba(31,41,55,0.08)" />
            {%- assign label_v = metric_y_max | times: 5 | minus: yspan | times: i | divided_by: 5 -%}
            <text x="40" y="{{ tick_y | plus: 4 }}" font-size="10" text-anchor="end" fill="rgba(31,41,55,0.55)">{{ label_v | round: 0 }}</text>
          {%- endfor -%}

          {%- comment -%} X axis ticks/labels: 9 ticks (0 .. metric_x_max) {%- endcomment -%}
          {%- for i in (0..8) -%}
            {%- assign tx = 456 | times: i | divided_by: 8 | plus: 48 -%}
            {%- assign tval = metric_x_max | times: i | divided_by: 8 -%}
            <line x1="{{ tx }}" y1="260" x2="{{ tx }}" y2="264" stroke="rgba(31,41,55,0.3)" />
            <text x="{{ tx }}" y="278" font-size="10" text-anchor="middle" fill="rgba(31,41,55,0.55)">{{ tval }}</text>
          {%- endfor -%}

          {%- comment -%} axis frame {%- endcomment -%}
          <line x1="48" y1="16" x2="48" y2="260" stroke="rgba(31,41,55,0.4)" />
          <line x1="48" y1="260" x2="504" y2="260" stroke="rgba(31,41,55,0.4)" />

          <text x="276" y="296" font-size="11" text-anchor="middle" fill="var(--color-secondary)" font-family="var(--font-heading)" font-weight="700">{{ metric_x_label }}</text>

          {%- comment -%}
            Lines (precomputed control points). Both lines go from i=0..8.
            "leading brand" drops steeply, M&S drops gently.
            Coordinates were precomputed in the React port — keeps the
            chart looking consistent without on-page JS.
          {%- endcomment -%}
          {%- comment -%} Compute screen-y for top (yMax) and bottom (yMin); innerH=244, padT=16 {%- endcomment -%}
          {%- assign y_at_top = 16 -%}
          {%- assign y_at_bot = 260 -%}

          {%- comment -%} M&S y-values: yMax minus 15% of yspan * (i/8) {%- endcomment -%}
          {%- assign ms_path = '' -%}
          {%- for i in (0..8) -%}
            {%- assign px = 456 | times: i | divided_by: 8 | plus: 48 -%}
            {%- assign frac = i | times: 100 | divided_by: 8 -%}
            {%- assign drop_pct = frac | times: 15 | divided_by: 100 -%}
            {%- assign py_offset = 244 | times: drop_pct | divided_by: 100 -%}
            {%- assign py = 16 | plus: py_offset -%}
            {%- if i == 0 -%}
              {%- assign ms_path = ms_path | append: 'M ' | append: px | append: ' ' | append: py -%}
            {%- else -%}
              {%- assign ms_path = ms_path | append: ' L ' | append: px | append: ' ' | append: py -%}
            {%- endif -%}
          {%- endfor -%}

          {%- assign other_path = '' -%}
          {%- for i in (0..8) -%}
            {%- assign px = 456 | times: i | divided_by: 8 | plus: 48 -%}
            {%- assign frac = i | times: 100 | divided_by: 8 -%}
            {%- comment -%} steep decline: starts ~18% below top, ends near bottom {%- endcomment -%}
            {%- assign drop_pct = 18 | plus: frac | times: 80 | divided_by: 100 -%}
            {%- assign py_offset = 244 | times: drop_pct | divided_by: 100 -%}
            {%- assign py = 16 | plus: py_offset -%}
            {%- if i == 0 -%}
              {%- assign other_path = other_path | append: 'M ' | append: px | append: ' ' | append: py -%}
            {%- else -%}
              {%- assign other_path = other_path | append: ' L ' | append: px | append: ' ' | append: py -%}
            {%- endif -%}
          {%- endfor -%}

          <path d="{{ other_path }}" fill="none" stroke="rgba(31,41,55,0.45)" stroke-width="2.5" stroke-dasharray="4 4" />
          <path d="{{ ms_path }}" fill="none" stroke="var(--color-primary)" stroke-width="3" />

          {%- comment -%} Legend in top-right of chart {%- endcomment -%}
          <g transform="translate(330,28)">
            <rect x="0" y="0" width="170" height="48" rx="8" fill="rgba(255,255,255,0.95)" stroke="rgba(31,41,55,0.12)" />
            <circle cx="14" cy="16" r="4" fill="var(--color-primary)" />
            <text x="26" y="20" font-size="11" font-family="var(--font-heading)" font-weight="700" fill="var(--color-text)">Molly &amp; Sophie</text>
            <circle cx="14" cy="34" r="4" fill="rgba(31,41,55,0.55)" />
            <text x="26" y="38" font-size="11" font-family="var(--font-heading)" font-weight="700" fill="rgba(31,41,55,0.7)">Leading brand</text>
          </g>
        </svg>
        <div class="product-test-results-caption">* {{ product.title | escape }} vs leading brand — internal testing</div>
      </div>

      <div class="product-test-results-copy" data-testid="product-test-results-copy">
        <h3>{{ metric_headline }}</h3>
        <p>{{ metric_body }}</p>
        <ul>
          <li><span aria-hidden="true">✓</span> Tested in real homes by real pet parents</li>
          <li><span aria-hidden="true">✓</span> Backed by our 30-day no-questions returns</li>
          <li><span aria-hidden="true">✓</span> 1% of every order goes to a hand-picked rescue</li>
        </ul>
      </div>
    </div>
  </div>
</section>
