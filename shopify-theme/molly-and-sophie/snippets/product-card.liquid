<a href="{{ product.url }}" class="product-card" data-testid="product-card-{{ product.handle }}">
  <div class="media">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
    {%- else -%}
      <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:5rem;color:var(--color-secondary);">🐾</div>
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
      <span class="badge">Sale</span>
    {%- elsif product.tags contains 'bestseller' -%}
      <span class="badge">Bestseller</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="badge">New</span>
    {%- endif -%}
    <button type="button"
            class="wishlist-heart"
            data-wishlist-toggle="{{ product.handle }}"
            data-product-title="{{ product.title | escape }}"
            aria-label="Save to wishlist"
            data-testid="wishlist-heart-{{ product.handle }}"
            onclick="event.preventDefault();event.stopPropagation();window.MollyWishlist&&window.MollyWishlist.toggle(this)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
  </div>
  <div class="info">
    {%- if product.vendor != blank -%}<div class="vendor">{{ product.vendor }}</div>{%- endif -%}
    <h3 class="title">{{ product.title }}</h3>
    <div class="price">
      {%- if product.compare_at_price > product.price -%}
        <span class="compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      {{ product.price | money }}
    </div>
  </div>
</a>

