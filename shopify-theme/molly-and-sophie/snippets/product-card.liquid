<a href="{{ product.url }}" class="product-card" data-testid="product-card-{{ product.handle }}">
  <div class="media">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
    {%- else -%}
      <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:5rem;color:var(--color-secondary);">🐾</div>
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
      <span class="badge">Sale</span>
    {%- elsif product.tags contains 'bestseller' -%}
      <span class="badge">Bestseller</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="badge">New</span>
    {%- endif -%}
  </div>
  <div class="info">
    {%- if product.vendor != blank -%}<div class="vendor">{{ product.vendor }}</div>{%- endif -%}
    <h3 class="title">{{ product.title }}</h3>
    <div class="price">
      {%- if product.compare_at_price > product.price -%}
        <span class="compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      {{ product.price | money }}
    </div>
  </div>
</a>
