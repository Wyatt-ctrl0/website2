{%- if settings.bundle_upsell_enabled -%}
{%- assign upsell_items_raw = settings.bundle_upsell_items | default: '🦴|Salmon Soft Treats|14.99|coral,🎾|Squeaky Plush Carrot|18.99|peach' -%}
{%- assign upsell_items = upsell_items_raw | split: ',' -%}
{%- assign upsell_compare = settings.bundle_upsell_compare | default: '33.98' | times: 1.0 -%}
{%- assign upsell_price = settings.bundle_upsell_price | default: '27.18' | times: 1.0 -%}
{%- assign upsell_save = upsell_compare | minus: upsell_price -%}
<div class="bundle-upsell-popup" data-bundle-upsell-popup data-testid="bundle-upsell-popup" role="dialog" aria-labelledby="bundle-upsell-title" aria-hidden="true">
  <div class="bundle-upsell-inner">
    <button class="bundle-upsell-close" data-bundle-upsell-close data-testid="bundle-upsell-close" aria-label="Close popup">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <span class="bundle-upsell-eyebrow">{{ settings.bundle_upsell_eyebrow | default: 'Wait — one more thing' }}</span>
    <h2 class="bundle-upsell-title" id="bundle-upsell-title">{{ settings.bundle_upsell_title | default: 'Bundle up &amp; <em>save</em> before you check out' }}</h2>
    <p class="bundle-upsell-subtitle">{{ settings.bundle_upsell_subtitle | default: 'Add these pup-favorites to your order at a discount — your pack will thank you.' }}</p>

    <div class="bundle-upsell-items">
      {%- for item in upsell_items -%}
        {%- assign parts = item | split: '|' -%}
        <div class="bundle-item bundle-item-{{ parts[3] | default: 'mint' }}" style="min-width: 130px;">
          <div class="bundle-item-emoji">{{ parts[0] }}</div>
          <div class="bundle-item-name">{{ parts[1] }}</div>
          <div class="bundle-item-price">${{ parts[2] }}</div>
        </div>
        {%- unless forloop.last -%}<div class="bundle-plus">+</div>{%- endunless -%}
      {%- endfor -%}
    </div>

    <div class="bundle-upsell-pricing">
      <div class="row"><span>Add-on total</span><span class="bundle-upsell-strike" style="text-decoration:line-through;color:rgba(31,41,55,0.5);">${{ upsell_compare }}</span></div>
      <div class="row save"><span>Bundle savings</span><span>− ${{ upsell_save }}</span></div>
      <div class="row total"><span>Add to your order</span><span>${{ upsell_price }}</span></div>
    </div>

    <div class="bundle-upsell-actions">
      <button type="button" class="btn btn-primary btn-block" data-bundle-upsell-add data-testid="bundle-upsell-add">
        ✨ Yes, add the bundle &amp; check out
      </button>
      <button type="button" class="bundle-upsell-skip" data-bundle-upsell-skip data-testid="bundle-upsell-skip">
        No thanks, just take me to checkout
      </button>
    </div>
  </div>
</div>
{%- endif -%}
