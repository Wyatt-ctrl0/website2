<section class="donation-banner" data-testid="donation-banner">
  <div class="container">
    <div class="donation-grid">
      <div>
        <h2>{{ section.settings.heading | default: '1% of every order helps rescue pets.' }}</h2>
        <p>{{ section.settings.subheading | default: 'We partner with the Humane Society of the Poconos to fund food, shelter, and medical care for animals waiting for their forever homes.' }}</p>
      </div>
      <div>
        <a href="{{ section.settings.button_link | default: 'https://humanepa.org/donate/' }}" target="_blank" rel="noopener" class="btn btn-primary" data-testid="donation-cta">{{ section.settings.button_text | default: 'Meet Our Partner' }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Donation Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "1% of every order helps rescue pets." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We partner with the Humane Society of the Poconos to fund food, shelter, and medical care for animals waiting for their forever homes." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Meet Our Partner" },
    { "type": "url", "id": "button_link", "label": "Button link", "default": "https://humanepa.org/donate/" }
  ],
  "presets": [{ "name": "Donation Banner" }]
}
{% endschema %}
