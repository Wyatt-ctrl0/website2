<section class="donation-banner" data-testid="donation-banner">
  <div class="container">
    <div class="donation-grid">
      <div>
        <h2>{{ section.settings.heading | default: '1% of every order. Donated monthly. To rescues we love.' }}</h2>
        <p>{{ section.settings.subheading | default: 'We are not affiliated with any single charity — every month we hand-pick a trusted pet rescue and donate 1% of our orders directly to them. Real animals. Real impact.' }}</p>
      </div>
      <div>
        <a href="{{ section.settings.button_link | default: '/pages/giving-back' }}" class="btn btn-primary" data-testid="donation-cta">{{ section.settings.button_text | default: 'How It Works' }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Donation Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "1% of every order. Donated monthly. To rescues we love." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We are not affiliated with any single charity — every month we hand-pick a trusted pet rescue and donate 1% of our orders directly to them. Real animals. Real impact." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "How It Works" },
    { "type": "url", "id": "button_link", "label": "Button link", "default": "/pages/giving-back" }
  ],
  "presets": [{ "name": "Donation Banner" }]
}
{% endschema %}
