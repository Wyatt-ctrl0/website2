{%- assign dog_name = section.settings.dog_name -%}
{%- assign dog_role = section.settings.dog_role -%}
{%- assign dog_bg = section.settings.bg_color | default: '#B5D6CD' -%}

<section class="dog-story-hero" style="background: {{ dog_bg }};" data-testid="dog-story-hero-{{ dog_name | handleize }}">
  <div class="container">
    <div class="dog-story-hero-grid">
      <div>
        <a href="/pages/about" class="back-link">← Back to Our Story</a>
        <span class="hero-eyebrow" style="margin-top:1rem;">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><circle cx="12" cy="12" r="4"/></svg>
          Meet {{ dog_name }}
        </span>
        <h1>{{ dog_name }}<br><em>{{ dog_role }}</em></h1>
        <p>{{ section.settings.tagline }}</p>
      </div>
      <div class="dog-story-hero-img-wrap">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="{{ dog_name }}">
        {%- else -%}
          <img src="{{ section.settings.fallback_url }}" alt="{{ dog_name }}">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<section class="dog-story-content">
  <div class="container" style="max-width: 760px;">
    {%- for block in section.blocks -%}
      {%- if block.type == 'paragraph' -%}
        <p>{{ block.settings.text }}</p>
      {%- elsif block.type == 'pullquote' -%}
        <blockquote>{{ block.settings.text }}</blockquote>
      {%- elsif block.type == 'heading' -%}
        <h2>{{ block.settings.text }}</h2>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{%- assign gallery_blocks = section.blocks | where: 'type', 'photo' -%}
{%- if gallery_blocks.size > 0 -%}
<section class="dog-photobooth section" data-testid="dog-photobooth-{{ dog_name | handleize }}">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ dog_name }}'s Photo Booth</span>
      <h2>Captured <em>moments</em></h2>
    </div>
    <div class="photobooth-grid">
      {%- for block in gallery_blocks -%}
        <div class="photobooth-tile photobooth-tile-{{ forloop.index | modulo: 4 | plus: 1 }}">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.caption | default: dog_name }}" loading="lazy">
          {%- else -%}
            <img src="{{ block.settings.fallback_url }}" alt="{{ block.settings.caption | default: dog_name }}" loading="lazy">
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <div class="photobooth-caption">{{ block.settings.caption }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<section class="dog-story-cta">
  <div class="container" style="max-width: 720px; text-align: center;">
    <h2>Help us help more like {{ dog_name }} <em>find homes</em></h2>
    <p>1% of every order is donated each month to a trusted pet rescue we believe in. Every purchase makes a difference.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/collections/all" class="btn btn-primary" data-testid="dog-story-shop">Shop the Pack</a>
      <a href="/pages/about" class="btn btn-outline" data-testid="dog-story-meet">Meet the Whole Pack</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dog Story",
  "max_blocks": 30,
  "settings": [
    { "type": "text", "id": "dog_name", "label": "Dog name", "default": "Jack" },
    { "type": "text", "id": "dog_role", "label": "Role / nickname", "default": "The Old Soul" },
    { "type": "color", "id": "bg_color", "label": "Hero background color", "default": "#B5D6CD" },
    { "type": "text", "id": "tagline", "label": "Hero tagline", "default": "His story, in his own little way." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero photo" },
    { "type": "text", "id": "fallback_url", "label": "Fallback image URL" }
  ],
  "blocks": [
    { "type": "heading", "name": "Heading", "settings": [{ "type": "text", "id": "text", "label": "Heading", "default": "How we met" }] },
    { "type": "paragraph", "name": "Paragraph", "settings": [{ "type": "textarea", "id": "text", "label": "Paragraph" }] },
    { "type": "pullquote", "name": "Pull quote", "settings": [{ "type": "textarea", "id": "text", "label": "Quote" }] },
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "fallback_url", "label": "Fallback URL" },
        { "type": "text", "id": "caption", "label": "Caption (optional)" }
      ]
    }
  ]
}
{% endschema %}
