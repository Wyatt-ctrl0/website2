{%- assign product = product -%}

<div class="product-page" data-testid="product-page">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumbs">
      <a href="/">Home</a> <span>›</span>
      <a href="/collections/all">Shop</a> <span>›</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="product-grid-main">
      <div class="product-gallery">
        <div class="main-img" data-lightbox="{{ product.featured_image | image_url: width: 2000 }}">
          {%- if product.featured_image != blank -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}" data-product-main-img>
          {%- else -%}
            <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:7rem;background:var(--color-mint);">🐾</div>
          {%- endif -%}
          {%- if product.compare_at_price > product.price -%}
            <span class="product-badge product-badge-sale">{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% OFF</span>
          {%- elsif product.tags contains 'bestseller' -%}
            <span class="product-badge product-badge-bestseller">Bestseller</span>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-thumbs">
            {%- for img in product.images -%}
              <button type="button" data-product-thumb data-img="{{ img | image_url: width: 1200 }}" class="{% if forloop.first %}is-active{% endif %}" data-testid="product-thumb-{{ forloop.index }}">
                <img src="{{ img | image_url: width: 200 }}" alt="">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} BUNDLE — sits under the product image, left column (above FAQ) {%- endcomment -%}
        {%- assign bundle_items_raw = product.metafields.custom.bundle_items | default: '🛏️|Cozy Donut Bed|29.99|mint,🦴|Salmon Soft Treats|14.99|coral,🎾|Squeaky Plush Carrot|18.99|peach' -%}
        {%- assign bundle_items = bundle_items_raw | split: ',' -%}
        {%- assign bundle_compare = product.metafields.custom.bundle_compare_price | default: '63.97' | times: 1.0 -%}
        {%- assign bundle_price = product.metafields.custom.bundle_price | default: '57.57' | times: 1.0 -%}
        {%- assign bundle_savings = bundle_compare | minus: bundle_price -%}
        {%- assign bundle_discount = product.metafields.custom.bundle_discount | default: '10' -%}
        <aside class="product-bundle" data-testid="product-bundle">
          <div class="product-bundle-head">
            <span class="product-bundle-eyebrow">Build a Bundle</span>
            <h3 class="product-bundle-heading">Save more with the <em>full kit</em></h3>
          </div>
          <div class="product-bundle-items">
            {%- for item in bundle_items -%}
              {%- assign parts = item | split: '|' -%}
              <div class="bundle-item bundle-item-{{ parts[3] | default: 'mint' }}" data-testid="bundle-item-{{ forloop.index0 }}">
                <div class="bundle-item-emoji">{{ parts[0] }}</div>
                <div class="bundle-item-name">{{ parts[1] }}</div>
                <div class="bundle-item-price">${{ parts[2] }}</div>
              </div>
              {%- unless forloop.last -%}
                <div class="bundle-plus" aria-hidden="true">+</div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
          <div class="product-bundle-cta">
            <div class="product-bundle-pricing">
              <span class="product-bundle-strike">${{ bundle_compare }}</span>
              <span class="product-bundle-price">Bundle: ${{ bundle_price }}</span>
              <span class="product-bundle-save">You save ${{ bundle_savings }}</span>
            </div>
            <button type="button" class="btn btn-primary btn-block product-bundle-btn" data-bundle-add data-testid="bundle-add-btn">
              🛒 Add Bundle to Cart
            </button>
            <p class="product-bundle-note">{{ bundle_discount }}% off when bought together</p>
          </div>
        </aside>

        {%- comment -%} FAQ — sits under the BUNDLE, left column {%- endcomment -%}
        <aside class="product-faq" data-testid="product-faq">
          <div class="product-faq-head">
            <span class="product-faq-eyebrow">Curious Pups</span>
            <h3 class="product-faq-heading">Frequently <em>asked</em></h3>
          </div>
          <div class="product-faq-list">
            {%- assign faq_raw = product.metafields.custom.faqs | default: 'How fast do orders ship?|Most orders leave our warehouse within 1–3 business days. You will get a tracking link the moment it ships.~~Is it safe for all dog sizes?|Yes — our premium pet-safe blend is tested and approved for small to large breeds.~~How do I clean it?|Spot-clean with mild soap or hand-wash gently. Always air dry before the next use.~~What is your return policy?|30-day, no-questions-asked returns. If your pup didn''t approve, send it back and we''ll make it right.' -%}
            {%- assign faq_pairs = faq_raw | split: '~~' -%}
            {%- for pair in faq_pairs -%}
              {%- assign kv = pair | split: '|' -%}
              <details class="product-faq-item" {% if forloop.first %}open{% endif %} data-testid="product-faq-item-{{ forloop.index0 }}">
                <summary data-testid="product-faq-toggle-{{ forloop.index0 }}">
                  <span>{{ kv[0] }}</span>
                  <span class="product-faq-icon" aria-hidden="true">+</span>
                </summary>
                <div class="product-faq-answer" data-testid="product-faq-answer-{{ forloop.index0 }}">{{ kv[1] }}</div>
              </details>
            {%- endfor -%}
          </div>
        </aside>
      </div>

      <div class="product-details">
        <div class="product-vendor">{{ product.vendor | default: 'Molly & Sophie' }}</div>
        <h1 class="product-title" data-testid="product-title">{{ product.title }}</h1>

        <div class="product-rating" aria-label="5 out of 5 stars">
          <span style="color:#f5b800;letter-spacing:0.1em;">★★★★★</span>
          <span style="color:rgba(31,41,55,0.55);font-size:0.9rem;">({{ product.metafields.reviews.count | default: 124 }} happy pets)</span>
        </div>

        <div class="product-price" data-testid="product-price">
          {%- if product.compare_at_price > product.price -%}
            <span class="compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          {{ product.price | money }}
          {%- if product.compare_at_price > product.price -%}
            <span class="save-pill">Save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>

        <div class="product-trust">
          <div class="trust-pill">🚚 Free shipping over ${{ settings.free_shipping_threshold | default: 50 }}</div>
          <div class="trust-pill">↩ 30-day easy returns</div>
          <div class="trust-pill">❤ 1% to pet rescues</div>
        </div>

        <div class="product-description rte">{{ product.description | default: '<p>Lovingly chosen by our pack. Pet-parent approved, vet-friendly, and built to last.</p>' }}</div>

        {%- form 'product', product, id: 'ProductForm' -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="product-options">
                <div class="option-label">{{ option.name }}: <span class="option-selected">{{ option.selected_value | default: option.values.first }}</span></div>
                <div class="option-values">
                  {%- for value in option.values -%}
                    <button type="button" class="option-value {% if forloop.first %}is-active{% endif %}" data-option-value data-option-group="{{ option.name }}" data-testid="option-{{ option.name | handleize }}-{{ value | handleize }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="product-quantity">
            <div class="qty-control">
              <button type="button" onclick="this.nextElementSibling.value=Math.max(1, parseInt(this.nextElementSibling.value)-1)" aria-label="Decrease">−</button>
              <input type="number" name="quantity" value="1" min="1" data-testid="product-qty">
              <button type="button" onclick="this.previousElementSibling.value=parseInt(this.previousElementSibling.value)+1" aria-label="Increase">+</button>
            </div>
            <button type="submit" class="btn btn-primary" style="flex:1" data-testid="add-to-cart-btn">
              {%- if product.available -%}Add to Cart · {{ product.price | money }}{%- else -%}Sold Out{%- endif -%}
            </button>
          </div>

          {%- if product.available -%}
            <button type="submit" name="checkout" class="btn btn-secondary btn-block" style="margin-top:0.75rem;" data-testid="buy-now-btn">⚡ Buy It Now</button>
          {%- endif -%}
        {%- endform -%}

        {%- comment -%} SPECS / DIMENSIONS / TESTER'S NOTE {%- endcomment -%}
        <div class="product-info-stack" data-testid="product-specs-section">
          <h3 class="product-info-stack-heading">Product details</h3>

          <div class="info-card">
            <div class="info-card-title">📋 Specs</div>
            <dl class="info-dl">
              {%- assign spec_pairs = product.metafields.custom.specs | default: 'Material|Premium pet-safe blend,Care|Spot-clean or hand-wash,Country of origin|USA,Best for|Small to large breeds' | split: ',' -%}
              {%- for pair in spec_pairs -%}
                {%- assign kv = pair | split: '|' -%}
                <dt>{{ kv[0] }}</dt><dd>{{ kv[1] }}</dd>
              {%- endfor -%}
            </dl>
          </div>

          <div class="info-card">
            <div class="info-card-title">📐 Dimensions</div>
            <table class="info-table">
              <tbody>
                {%- assign dim_rows = product.metafields.custom.dimensions | default: 'Small|5 × 4 × 1 in · 0.3 lb,Medium|7 × 5 × 1.5 in · 0.5 lb,Large|9 × 6 × 2 in · 0.8 lb' | split: ',' -%}
                {%- for row in dim_rows -%}
                  {%- assign kv = row | split: '|' -%}
                  <tr><td>{{ kv[0] }}</td><td>{{ kv[1] }}</td></tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>

          <div class="info-card info-card-tester">
            <div class="tester-header">
              <div class="tester-avatar">{{ product.metafields.custom.tester_initial | default: 'S' }}</div>
              <div>
                <div class="tester-name">{{ product.metafields.custom.tester_name | default: 'Sophie' }}'s tester note</div>
                <div class="tester-role">Chief product officer (4 paws, 2 ears)</div>
              </div>
            </div>
            <p class="tester-note">"{{ product.metafields.custom.tester_note | default: 'Approved with three full tail-wags and a stolen sock as celebration. She tried to share with Molly. Molly declined. We call that 5 stars.' }}"</p>
          </div>
        </div>

        <details class="product-accordion" open>
          <summary>What pet parents love</summary>
          <ul class="product-features-list">
            <li>✓ Curated by real pet parents (us!)</li>
            <li>✓ Tested and approved by Jack, Sophie & Molly</li>
            <li>✓ 1% donated monthly to a hand-picked pet rescue</li>
            <li>✓ Easy 30-day returns — no questions asked</li>
            <li>✓ Ships in 1–3 business days from the USA</li>
          </ul>
        </details>

        <details class="product-accordion">
          <summary>Shipping & returns</summary>
          <p>Free shipping on orders over ${{ settings.free_shipping_threshold | default: 50 }}. We ship within 1–3 business days. Not loving it? Return within 30 days for a full refund.</p>
        </details>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Why-ours-wins — competitor comparison chart {%- endcomment -%}
{%- assign cmp_title = product.metafields.custom.compare_title | default: 'Why ours <em>outlasts</em> the rest' -%}
{%- assign cmp_eyebrow = product.metafields.custom.compare_eyebrow | default: 'Tested vs the leading brand' -%}
{%- assign cmp_y_unit = product.metafields.custom.compare_y_unit | default: '°F' -%}
{%- assign cmp_x_label = product.metafields.custom.compare_x_label | default: 'Time / Min' -%}
{%- assign cmp_ours_label = product.metafields.custom.compare_ours_label | default: 'Molly & Sophie' -%}
{%- assign cmp_them_label = product.metafields.custom.compare_them_label | default: 'Average competitor' -%}
{%- comment -%} 9 data points each, comma-separated. Mapped onto a 0..100 percent scale of the chart. {%- endcomment -%}
{%- assign cmp_ours_raw = product.metafields.custom.compare_ours_data | default: '82,84,86,88,89,91,93,95,96' -%}
{%- assign cmp_them_raw = product.metafields.custom.compare_them_data | default: '82,90,94,96,97,98,99,99,99' -%}
{%- assign cmp_x_ticks = product.metafields.custom.compare_x_ticks | default: '0,30,60,90,120,150,180,210,240' -%}
{%- assign cmp_y_ticks = product.metafields.custom.compare_y_ticks | default: '80,84,88,92,96,100' -%}
{%- assign cmp_blurb = product.metafields.custom.compare_blurb | default: 'Independent bench tests show our pad stays cooler, longer. While competitors heat up within the first hour, ours holds its temperature for up to 3 hours of constant use — and recharges itself after just 15–20 minutes of rest.' -%}

<section class="section product-compare-section reveal" data-testid="product-compare">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ cmp_eyebrow }}</span>
      <h2>{{ cmp_title }}</h2>
    </div>

    <div class="product-compare-grid">
      <div class="product-compare-chart">
        {%- assign ours_pts = cmp_ours_raw | split: ',' -%}
        {%- assign them_pts = cmp_them_raw | split: ',' -%}
        {%- assign x_ticks = cmp_x_ticks | split: ',' -%}
        {%- assign y_ticks = cmp_y_ticks | split: ',' -%}
        {%- assign y_min = y_ticks.first | plus: 0 -%}
        {%- assign y_max = y_ticks.last | plus: 0 -%}
        {%- assign y_range = y_max | minus: y_min -%}

        <svg viewBox="0 0 600 380" role="img" aria-labelledby="cmpTitle cmpDesc" class="compare-svg">
          <title id="cmpTitle">{{ cmp_ours_label }} vs {{ cmp_them_label }}</title>
          <desc id="cmpDesc">Comparison line chart showing our product outperforming the competition over time.</desc>

          {%- comment -%} chart frame: x:60..580 (520 wide), y:30..310 (280 tall) {%- endcomment -%}
          <rect class="cmp-frame" x="60" y="30" width="520" height="280" stroke-width="2" rx="6"/>

          {%- comment -%} horizontal gridlines + Y labels {%- endcomment -%}
          {%- for t in y_ticks -%}
            {%- assign t_num = t | plus: 0 -%}
            {%- assign t_pct = t_num | minus: y_min | times: 1.0 | divided_by: y_range -%}
            {%- assign y_pos = t_pct | times: 280 -%}
            {%- assign y_pos = 310 | minus: y_pos -%}
            <line x1="60" y1="{{ y_pos }}" x2="580" y2="{{ y_pos }}" stroke="rgba(31,41,55,0.08)" stroke-width="1"/>
            <text x="50" y="{{ y_pos | plus: 4 }}" text-anchor="end" font-size="12" fill="rgba(31,41,55,0.6)" font-family="system-ui,sans-serif">{{ t }}</text>
          {%- endfor -%}
          <text class="cmp-axis-unit" x="20" y="22" font-size="13" font-weight="700" font-family="system-ui,sans-serif">{{ cmp_y_unit }}</text>

          {%- comment -%} X labels {%- endcomment -%}
          {%- assign x_count = x_ticks.size | minus: 1 -%}
          {%- for tx in x_ticks -%}
            {%- assign x_idx = forloop.index0 -%}
            {%- assign x_pct = x_idx | times: 1.0 | divided_by: x_count -%}
            {%- assign x_pos = x_pct | times: 520 | plus: 60 -%}
            <text x="{{ x_pos }}" y="332" text-anchor="middle" font-size="12" fill="rgba(31,41,55,0.6)" font-family="system-ui,sans-serif">{{ tx }}</text>
          {%- endfor -%}
          <text class="cmp-x-label" x="320" y="358" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif">{{ cmp_x_label }}</text>

          {%- comment -%} Build polyline strings for each series {%- endcomment -%}
          {%- assign series_count = ours_pts.size | minus: 1 -%}

          {%- capture ours_path -%}
            {%- for v in ours_pts -%}
              {%- assign vn = v | plus: 0 -%}
              {%- assign vp = vn | minus: y_min | times: 1.0 | divided_by: y_range -%}
              {%- assign yy = vp | times: 280 -%}
              {%- assign yy = 310 | minus: yy -%}
              {%- assign xp = forloop.index0 | times: 1.0 | divided_by: series_count -%}
              {%- assign xx = xp | times: 520 | plus: 60 -%}
              {{ xx }},{{ yy }}{% unless forloop.last %} {% endunless %}
            {%- endfor -%}
          {%- endcapture -%}

          {%- capture them_path -%}
            {%- for v in them_pts -%}
              {%- assign vn = v | plus: 0 -%}
              {%- assign vp = vn | minus: y_min | times: 1.0 | divided_by: y_range -%}
              {%- assign yy = vp | times: 280 -%}
              {%- assign yy = 310 | minus: yy -%}
              {%- assign xp = forloop.index0 | times: 1.0 | divided_by: series_count -%}
              {%- assign xx = xp | times: 520 | plus: 60 -%}
              {{ xx }},{{ yy }}{% unless forloop.last %} {% endunless %}
            {%- endfor -%}
          {%- endcapture -%}

          {%- comment -%} Competitor line (muted) {%- endcomment -%}
          <polyline points="{{ them_path | strip }}" fill="none" stroke="rgba(31,41,55,0.45)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- for v in them_pts -%}
            {%- assign vn = v | plus: 0 -%}
            {%- assign vp = vn | minus: y_min | times: 1.0 | divided_by: y_range -%}
            {%- assign yy = vp | times: 280 -%}
            {%- assign yy = 310 | minus: yy -%}
            {%- assign xp = forloop.index0 | times: 1.0 | divided_by: series_count -%}
            {%- assign xx = xp | times: 520 | plus: 60 -%}
            <circle cx="{{ xx }}" cy="{{ yy }}" r="4" fill="rgba(31,41,55,0.55)"/>
          {%- endfor -%}

          {%- comment -%} Our line (primary) {%- endcomment -%}
          <polyline class="cmp-line-ours" points="{{ ours_path | strip }}" fill="none" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- for v in ours_pts -%}
            {%- assign vn = v | plus: 0 -%}
            {%- assign vp = vn | minus: y_min | times: 1.0 | divided_by: y_range -%}
            {%- assign yy = vp | times: 280 -%}
            {%- assign yy = 310 | minus: yy -%}
            {%- assign xp = forloop.index0 | times: 1.0 | divided_by: series_count -%}
            {%- assign xx = xp | times: 520 | plus: 60 -%}
            <circle class="cmp-dot-ours" cx="{{ xx }}" cy="{{ yy }}" r="5" stroke-width="2"/>
          {%- endfor -%}

          {%- comment -%} Legend {%- endcomment -%}
          <g transform="translate(360,52)">
            <rect class="cmp-legend-box" x="0" y="0" width="210" height="58" rx="8"/>
            <circle cx="16" cy="20" r="5" fill="rgba(31,41,55,0.55)"/>
            <text class="cmp-legend-text" x="30" y="24" font-size="13" font-family="system-ui,sans-serif">{{ cmp_them_label }}</text>
            <circle class="cmp-dot-ours" cx="16" cy="42" r="5"/>
            <text class="cmp-legend-text" x="30" y="46" font-size="13" font-weight="700" font-family="system-ui,sans-serif">{{ cmp_ours_label }}</text>
          </g>
        </svg>
        <p class="compare-caption">* Independent comparison test results</p>
      </div>

      <div class="product-compare-copy">
        <h3 class="product-compare-headline">Stays cooler. Lasts longer. Built for pups, not profit margins.</h3>
        <p class="product-compare-blurb">{{ cmp_blurb }}</p>
        <ul class="product-compare-bullets">
          <li><strong>Up to 3 hours</strong> of constant performance per use</li>
          <li><strong>15–20 min</strong> auto-recharge between sessions</li>
          <li><strong>Pet-safe blend</strong> — vet-friendly, non-toxic, chew-resistant</li>
        </ul>
      </div>
    </div>
  </div>
</section>

{%- comment -%} Recommendations {%- endcomment -%}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">You'll Also Love</span>
      <h2>More for the <em>pack</em></h2>
    </div>
    <div class="products-grid">
      {%- assign related = collections.all.products | where: 'available' -%}
      {%- for prod in related limit: 4 -%}
        {%- if prod.id != product.id -%}
          {% render 'product-card', product: prod %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
