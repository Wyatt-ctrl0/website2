<div class="collection-header" data-testid="collection-header">
  <div class="container">
    <span class="eyebrow" style="display:inline-block;font-family:var(--font-heading);font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-secondary);margin-bottom:1rem;">Collection</span>
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="collection-toolbar">
      <div class="product-count" data-testid="product-count">{{ collection.products_count | default: collection.all_products_count }} products</div>
    </div>

    <div class="products-grid">
      {%- if collection.products.size > 0 -%}
        {%- paginate collection.products by 24 -%}
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <div class="pagination text-center mt-4" style="grid-column: 1/-1;">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="btn btn-outline btn-sm">← Previous</a>{%- endif -%}
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="btn btn-outline btn-sm">Next →</a>{%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div style="grid-column: 1/-1; text-align:center; padding: 3rem;">
          <h3>No products in this collection yet.</h3>
          <p>Check back soon — we're always adding new goodies!</p>
          <a href="/collections/all" class="btn btn-primary mt-2">Browse All</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
