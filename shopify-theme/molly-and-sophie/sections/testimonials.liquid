<section class="testimonials section" data-testid="testimonials">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Wagging Reviews</span>
      <h2>{{ section.settings.heading | default: 'Happy pets, <em>happier humans</em>' }}</h2>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" data-testid="testimonial-{{ forloop.index }}">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">"{{ block.settings.text }}"</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{{ block.settings.author | slice: 0, 1 | upcase }}</div>
            <div>
              <div class="testimonial-name">{{ block.settings.author }}</div>
              <div class="testimonial-pet">{{ block.settings.pet }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Happy pets, <em>happier humans</em>" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Review", "default": "My pup loves the treats and we love that part of our purchase goes to helping rescues." },
        { "type": "text", "id": "author", "label": "Author", "default": "Sarah M." },
        { "type": "text", "id": "pet", "label": "Pet name & breed", "default": "Mom of Biscuit, Golden Retriever" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "text": "Salmon treats are a HIT in my house. Bonus points for the cute packaging and the donation to rescues!", "author": "Sarah M.", "pet": "Mom of Biscuit, Golden Retriever" } },
        { "type": "review", "settings": { "text": "Such warm, thoughtful packaging. You can tell real pet parents are behind this brand. Will absolutely reorder.", "author": "Marcus T.", "pet": "Dad of Olive, Tabby Cat" } },
        { "type": "review", "settings": { "text": "Knowing 1% goes to rescues makes every purchase feel meaningful. Plus, the harness fits my Molly perfectly!", "author": "Priya K.", "pet": "Mom of Toby, Mini Schnauzer" } }
      ]
    }
  ]
}
{% endschema %}
