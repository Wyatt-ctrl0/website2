<footer class="site-footer" data-testid="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">{{ settings.logo_text_part1 | default: 'Molly' }}<span> {{ settings.logo_text_part2 | default: '& Sophie' }}</span></a>
        <p>A small, family-run pet shop inspired by our three rescues — Jack, Sophie, and Molly. Every order helps fund pet rescues across the country.</p>
        <div class="socials" data-testid="footer-socials">
          {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" data-testid="social-instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.18 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.18 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.91.33 4.15.63a5.85 5.85 0 0 0-2.12 1.38A5.85 5.85 0 0 0 .65 4.13C.34 4.9.14 5.77.08 7.04.02 8.32 0 8.73 0 12s.01 3.68.07 4.95c.06 1.27.26 2.14.56 2.9.32.81.74 1.5 1.38 2.13a5.85 5.85 0 0 0 2.12 1.38c.77.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.14-.26 2.91-.56a5.85 5.85 0 0 0 2.12-1.38 5.85 5.85 0 0 0 1.38-2.12c.3-.77.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.14-.56-2.9a5.85 5.85 0 0 0-1.38-2.13A5.85 5.85 0 0 0 19.85.65C19.09.34 18.22.14 16.95.08 15.67.02 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg>
          </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" data-testid="social-facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.5h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.89v2.26h3.32l-.53 3.5h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" data-testid="social-tiktok">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.5 20.1a6.34 6.34 0 0 0 10.86-4.43V8.16A8.16 8.16 0 0 0 21 9.85V6.41a4.85 4.85 0 0 1-1.41-.27"/></svg>
          </a>
          {%- endif -%}
        </div>
      </div>

      <div class="footer-col">
        <h4>Customer Care</h4>
        <ul>
          <li><a href="/pages/returns" data-testid="footer-returns">Returns</a></li>
          <li><a href="/pages/shipping-info" data-testid="footer-shipping">Shipping Info</a></li>
          <li><a href="/pages/order-lookup" data-testid="footer-order-lookup">Order Lookup</a></li>
          <li><a href="/pages/help" data-testid="footer-help">Help Center</a></li>
          <li><a href="/pages/contact" data-testid="footer-contact-link">Contact Us</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>About</h4>
        <ul>
          <li><a href="/pages/about">Our Story</a></li>
          <li><a href="/pages/our-rescues">Meet the Pack</a></li>
          <li><a href="/pages/giving-back">Giving Back</a></li>
          <li><a href="/blogs/news">Blog</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Get in Touch</h4>
        <ul>
          <li><a href="mailto:{{ settings.email | default: 'support@mollyandsophie.com' }}" data-testid="footer-email">{{ settings.email | default: 'support@mollyandsophie.com' }}</a></li>
          <li><a href="tel:{{ settings.phone | default: '+15706711534' | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' }}" data-testid="footer-phone">{{ settings.phone | default: '(570) 671-1534' }}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div>© {{ 'now' | date: '%Y' }} Molly &amp; Sophie. Made with 🐾 for pets everywhere.</div>
      <div><a href="/policies/privacy-policy">Privacy</a> · <a href="/policies/terms-of-service">Terms</a></div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
