<section class="section" data-testid="contact-page">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">We'd Love to Hear From You</span>
      <h1>Get in <em>touch</em></h1>
      <p>Questions, feedback, or just want to share photos of your pet? We read every email.</p>
    </div>

    <div class="contact-grid">
      <div>
        <h3 style="margin-bottom:1.5rem;">Reach out</h3>
        <div class="contact-info-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h4>Email us</h4>
            <p style="margin:0;"><a href="mailto:{{ settings.email | default: 'support@mollyandsophie.com' }}" data-testid="contact-email">{{ settings.email | default: 'support@mollyandsophie.com' }}</a></p>
            <p style="margin:.25rem 0 0;font-size:.85rem;color:rgba(31,41,55,0.6);">We reply within 24 hours.</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h4>Call us</h4>
            <p style="margin:0;"><a href="tel:+15706711534" data-testid="contact-phone">{{ settings.phone | default: '(570) 671-1534' }}</a></p>
            <p style="margin:.25rem 0 0;font-size:.85rem;color:rgba(31,41,55,0.6);">Mon–Fri, 9am–5pm ET.</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <div>
            <h4>Response time</h4>
            <p style="margin:0;">Within 24 hours, M-F</p>
          </div>
        </div>
      </div>

      <div>
        <h3 style="margin-bottom:1.5rem;">Send a message</h3>
        {%- form 'contact', class: 'contact-form', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success" data-testid="contact-success">✓ Thanks! We'll get back to you soon.</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="form-error">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div>
            <label>Name</label>
            <input type="text" name="contact[name]" required data-testid="contact-name">
          </div>
          <div>
            <label>Email</label>
            <input type="email" name="contact[email]" required data-testid="contact-input-email">
          </div>
          <div>
            <label>Subject</label>
            <input type="text" name="contact[subject]" data-testid="contact-subject">
          </div>
          <div>
            <label>Message</label>
            <textarea name="contact[body]" required data-testid="contact-message"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" data-testid="contact-submit">Send Message</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Contact", "settings": [] }
{% endschema %}
