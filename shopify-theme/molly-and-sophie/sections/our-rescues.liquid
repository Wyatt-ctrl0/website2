<section class="rescues reveal" data-testid="our-rescues">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Meet The Pack</span>
      <h2>{{ section.settings.heading | default: 'Three rescues. <em>One mission.</em>' }}</h2>
      <p>{{ section.settings.subheading | default: 'These three goofballs are the heart of everything we do — they inspired our shop and remind us every day why rescues matter.' }}</p>
    </div>

    <div class="rescues-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="rescue-card" data-testid="rescue-card-{{ block.settings.name | handleize }}">
          <div class="rescue-photo">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 360 }}" alt="{{ block.settings.name }}">
            {%- else -%}
              <img src="{{ block.settings.fallback_url }}" alt="{{ block.settings.name }}">
            {%- endif -%}
          </div>
          <h3>{{ block.settings.name }}</h3>
          <div class="role">{{ block.settings.role }}</div>
          <p>{{ block.settings.bio }}</p>
          <span class="rescue-link">Read {{ block.settings.name }}'s story →</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Rescues",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three rescues. <em>One mission.</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "These three goofballs are the heart of everything we do — they inspired our shop and remind us every day why rescues matter." }
  ],
  "blocks": [
    {
      "type": "rescue",
      "name": "Rescue",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "fallback_url", "label": "Fallback image URL" },
        { "type": "text", "id": "name", "label": "Name", "default": "Rescue Name" },
        { "type": "text", "id": "role", "label": "Role / nickname", "default": "The cuddle bug" },
        { "type": "textarea", "id": "bio", "label": "Bio", "default": "A short story about this rescue." },
        { "type": "url", "id": "link", "label": "Story page link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Rescues",
      "blocks": [
        { "type": "rescue", "settings": { "name": "Jack", "role": "The Old Soul", "bio": "His previous owners traveled often for work and couldn't give him the attention he needed. Today, Jack is the calmest member of the pack and an expert sunbeam-finder.", "fallback_url": "https://customer-assets.emergentagent.com/job_6d3e1c7b-f001-4e06-8ed8-3843020b086b/artifacts/q86lwpgi_IMG_1473.jpg", "link": "/pages/jack" }},
        { "type": "rescue", "settings": { "name": "Sophie", "role": "The Fluffy Diplomat", "bio": "Sophie was left behind during quarantine — her previous family said they couldn't keep her. Their loss; our luckiest day. She greets everyone like a long-lost friend.", "fallback_url": "https://customer-assets.emergentagent.com/job_6d3e1c7b-f001-4e06-8ed8-3843020b086b/artifacts/g2hrd7bt_IMG_9494.jpg", "link": "/pages/sophie" }},
        { "type": "rescue", "settings": { "name": "Molly", "role": "The Sunshine", "bio": "Molly's first owners couldn't afford to care for her. She came to us scared and unsure — now she's pure goofy puppy joy and the reason we started this shop.", "fallback_url": "https://customer-assets.emergentagent.com/job_6d3e1c7b-f001-4e06-8ed8-3843020b086b/artifacts/yvrv5cn8_IMG_9662.jpg", "link": "/pages/molly" }}
      ]
    }
  ]
}
{% endschema %}
