{%- assign collection = collections[section.settings.collection] -%}

<section class="section" data-testid="featured-collection" style="background: var(--color-bg);">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Best Sellers' }}</span>
      <h2>{{ section.settings.heading | default: 'Tail-wagging <em>favorites</em>' }}</h2>
      <p>{{ section.settings.subheading | default: 'Hand-picked goodies our pack approves of.' }}</p>
    </div>

    <div class="products-grid">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {% comment %} Placeholder products for demo {% endcomment %}
        {%- assign placeholders = 'Salmon Soft Treats|Cozy Donut Bed|Squeaky Plush Carrot|Adventure Harness|Calming Chew Sticks|Catnip Mouse Trio|Premium Kibble Bowl|Plaid Travel Coat' | split: '|' -%}
        {%- assign prices = '14|49|18|34|22|12|26|44' | split: '|' -%}
        {%- assign emojis = '🦴|🛏️|🎾|🦮|🌿|🐱|🥣|🧥' | split: '|' -%}
        {%- for ph in placeholders limit: section.settings.limit -%}
          <div class="product-card" data-testid="product-card-demo-{{ forloop.index }}">
            <div class="media" style="background: {%- cycle '#ffe4d4', '#d2efef', '#fce8da', '#e8f0d4' -%}; display:flex; align-items:center; justify-content:center; font-size:5rem;">
              {{ emojis[forloop.index0] }}
              {%- if forloop.index0 == 0 -%}<span class="badge">Bestseller</span>{%- endif -%}
            </div>
            <div class="info">
              <div class="vendor">Molly &amp; Sophie</div>
              <a href="/products/sample" class="title">{{ ph }}</a>
              <div class="price">${{ prices[forloop.index0] }}.99</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="text-center mt-4">
        <a href="{{ collection.url | default: '/collections/all' }}" class="btn btn-outline" data-testid="featured-view-all">View All Products</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best Sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tail-wagging <em>favorites</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Hand-picked goodies our pack approves of." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' button", "default": true }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
